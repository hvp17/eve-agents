{
  "name": "eve-agents",
  "version": "0.1.0",
  "description": "CLI for discovering and installing Eve agent templates",
  "type": "module",
  "bin": {
    "eve-agents": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/catalog.json"
  ],
  "scripts": {
    "build": "tsc && node scripts/bundle-catalog.mjs",
    "dev": "node scripts/bundle-catalog.mjs && tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
